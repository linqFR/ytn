{
  "name": "ytn",
  "private": true,
  "description": "Monorepo for the YTN project",
  "type": "module",
  "workspaces": [
    "packages/*",
    "shared"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:performance": "vitest run '**/performance/**/*.test.ts' '**/benchmarks/**/*.test.ts'",
    "check": "npx.cmd tsc --noEmit",
    "change": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "tag": "changeset tag"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@types/node": "^26.1.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "tsup": "^8.3.5",
    "typescript": "npm:@typescript/typescript6@^6.0.3",
    "vitest": "^4.1.10",
    "zod-aot": "^0.21.0"
  }
}
