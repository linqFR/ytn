{
  "name": "ytn",
  "private": true,
  "description": "Monorepo for the YTN project",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
