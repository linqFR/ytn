{
  "name": "@ytn/tbx",
  "version": "1.0.1",
  "description": "Toolbox containing Utilities for Zod, Nodejs, Safe-to-Go",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./isPureObject": {
      "types": "./dist/isPureObject.d.ts",
      "import": "./dist/isPureObject.js"
    },
    "./protectObject": {
      "types": "./dist/protectObject.d.ts",
      "import": "./dist/protectObject.js"
    },
    "./catchAsyncFn": {
      "types": "./dist/catchAsyncFn.d.ts",
      "import": "./dist/catchAsyncFn.js"
    },
    "./min": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.min.js"
    }
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "zod": "^4.3.6"
  }
}
