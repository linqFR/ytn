{
  "name": "@ytn/qb",
  "version": "1.3.0",
  "description": "SQLite Query Builder",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "tsx tests/v4_compliance_verify.ts && tsx tests/query_construction_verify.ts && tsx tests/advanced_query_verify.ts && tsx tests/readme_examples.test.ts"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./min": {
      "import": "./dist/index.min.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "zod": "^4.3.6"
  }
}
