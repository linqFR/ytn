{
  "name": "cz",
  "version": "0.0.0",
  "description": "Transforme Command lines into Zod-validated Objects",
  "author": "linqFR",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "CLI",
    "Zod"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "tsx tests/index.ts"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./min": {
      "import": "./dist/index.min.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "zod": "^4.3.6"
  }
}
