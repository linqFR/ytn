{
  "name": "@ytn/czvo",
  "version": "2.1.0",
  "description": "Transform Command lines into Zod-Validated Objects (ZVO)",
  "author": "linqFR",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/linqFR/ytn.git",
    "directory": "packages/cli-to-zvo"
  },
  "bugs": {
    "url": "https://github.com/linqFR/ytn/issues"
  },
  "homepage": "https://github.com/linqFR/ytn/tree/main/packages/cli-to-zvo#readme",
  "type": "module",
  "keywords": [
    "CLI",
    "Zod"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./min": {
      "import": "./dist/index.min.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./editor": {
      "import": "./dist/editor.js",
      "types": "./dist/editor.d.ts"
    },
    "./launcher": {
      "import": "./dist/launcher.js",
      "types": "./dist/launcher.d.ts"
    }
  },
  "bin": {
    "czvo-compile": "./dist/cli.js"
  },
  "devDependencies": {
    "@ytn/shared": "*",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "zod": "^4.3.6"
  }
}
