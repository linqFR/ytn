{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@shared": ["shared/index.ts"],
    }
  },
  "exclude": ["**/node_modules", "**/dist", "**/docs", "**/dev_tools", "**/sandbox", "**/archive"]
}
